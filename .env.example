# ── Escala Connect — variáveis de ambiente ──
# Copie para .env e preencha com valores reais. O .env NÃO é versionado (.gitignore).

# ── Django ──
# Gere uma chave nova com:
#   python -c "import secrets,string; print(''.join(secrets.choice(string.ascii_lowercase+string.digits+'!@#$%^&*(-_=+)') for _ in range(50)))"
SECRET_KEY=troque-por-uma-chave-secreta-unica
DEBUG=False
# Domínios autorizados (separados por vírgula)
ALLOWED_HOSTS=connect.simoesti.com.br,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://connect.simoesti.com.br

# Opcionais de segurança — ative só depois de confirmar o proxy HTTPS:
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True

# ── Banco de dados (PostgreSQL) ──
POSTGRES_DB=escalaconnect
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-a-senha
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── E-mail (SMTP Gmail) ──
EMAIL_HOST_USER=seu-email@gmail.com
EMAIL_HOST_PASSWORD=senha-de-app-do-gmail

# ── Celery / Redis ──
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
# USE_DJANGO_CELERY_RESULTS=false
# CELERY_TASK_TIME_LIMIT=300

# ── Logs ──
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO
